{
  "name": "@kembec/eslint-config",
  "version": "2.1.0",
  "description": "Opinionated ESLint flat config for TypeScript, React, Vue & Vitest — strict type-aware rules, auto import sorting and Prettier",
  "main": "index.js",
  "exports": {
    ".": "./index.js"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kembec/eslint-config-kembec.git"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "opinionated",
    "strict",
    "shareable-config",
    "typescript",
    "react",
    "vue",
    "vitest",
    "prettier",
    "import-sort",
    "javascript",
    "node",
    "kembec"
  ],
  "author": "Kembec.com",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/Kembec/eslint-config-kembec/issues"
  },
  "homepage": "https://github.com/Kembec/eslint-config-kembec#readme",
  "dependencies": {
    "@eslint/js": "^9.27.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/eslint-plugin": "^1.6.17",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.34.0",
    "vue-eslint-parser": "^10.4.0"
  },
  "devDependencies": {
    "eslint": "^9.27.0",
    "jest": "^30.2.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "eslint": "^9.0.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": ["unrs-resolver"]
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module"
}